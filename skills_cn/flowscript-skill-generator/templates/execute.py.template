"""执行目标技能的确定性主步骤。TODO：替换占位业务逻辑。"""

from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any


def read_object(path: Path) -> dict[str, Any]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError("参数必须是 JSON 对象。")
    return data


def write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def main() -> int:
    parser = argparse.ArgumentParser(description="执行技能主步骤。")
    parser.add_argument("--input", required=True, type=Path, help="规范化参数 JSON 路径。")
    parser.add_argument("--output", required=True, type=Path, help="结果 artifact 路径。")
    parser.add_argument("--status-output", required=True, type=Path, help="执行状态 JSON 路径。")
    args = parser.parse_args()
    try:
        params = read_object(args.input)
        # TODO：在此实现确定性业务逻辑，并替换占位结果。
        result = {"summary": "已完成占位执行；请实现目标技能的业务逻辑。", "input": params}
        write_json(args.output, result)
        status = {"state": "success", "message": "执行完成。", "warnings": ["当前仍使用占位业务逻辑。"]}
        write_json(args.status_output, status)
        return 0
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        status = {"state": "recoverable_error", "message": f"执行失败：{exc}", "warnings": []}
        write_json(args.status_output, status)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
