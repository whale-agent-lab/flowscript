"""校验并规范化 FlowScript 输入。TODO：补充目标技能的业务规则。"""

from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any


def read_object(path: Path) -> dict[str, Any]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError("输入必须是 JSON 对象。")
    return data


def write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def validate(data: dict[str, Any]) -> tuple[dict[str, Any], dict[str, Any]]:
    missing = [name for name in ("source",) if not data.get(name)]
    if missing:
        return data, {
            "state": "needs_input",
            "message": "缺少继续执行所需的信息。",
            "missing_fields": missing,
            "warnings": [],
        }
    normalized = {"source": str(data["source"]).strip(), "options": data.get("options", {})}
    return normalized, {"state": "valid", "message": "输入校验通过。", "missing_fields": [], "warnings": []}


def main() -> int:
    parser = argparse.ArgumentParser(description="校验并规范化技能输入。")
    parser.add_argument("--input", required=True, type=Path, help="输入 JSON 路径。")
    parser.add_argument("--output", required=True, type=Path, help="校验状态 JSON 路径。")
    parser.add_argument("--normalized-output", type=Path, help="规范化参数 JSON 路径。")
    args = parser.parse_args()
    try:
        normalized, status = validate(read_object(args.input))
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        status = {"state": "invalid", "message": f"输入无效：{exc}", "missing_fields": [], "warnings": []}
        write_json(args.output, status)
        return 2
    write_json(args.output, status)
    if status["state"] == "valid" and args.normalized_output:
        write_json(args.normalized_output, normalized)
    return 0 if status["state"] == "valid" else 1


if __name__ == "__main__":
    raise SystemExit(main())
