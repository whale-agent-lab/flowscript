{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SyntheticCsvQualityReportInput",
  "description": "员工与区域模拟 CSV 数据质量及聚类报告的输入参数。",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "employees": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1},
      "description": "用户提供的员工名称。"
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1},
      "description": "用户提供的区域名称。"
    },
    "group_by": {
      "type": "string",
      "enum": ["employee", "region"],
      "description": "聚类维度：按员工或按区域。"
    },
    "time_range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"}
      },
      "required": ["start_date", "end_date"],
      "description": "可选闭区间；省略时默认截至当天的最近 30 天。"
    },
    "record_count": {
      "type": "integer",
      "minimum": 100,
      "maximum": 100000,
      "default": 5000,
      "description": "生成的模拟历史记录数。"
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647,
      "default": 42,
      "description": "用于复现模拟数据的随机种子。"
    },
    "report_title": {
      "type": "string",
      "minLength": 1,
      "default": "员工与区域数据质量报告",
      "description": "最终报告的中文标题。"
    }
  },
  "required": ["employees", "regions", "group_by"]
}
