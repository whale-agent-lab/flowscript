"""Validate and normalize FlowScript input. TODO: add target-specific business rules."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any


def read_object(path: Path) -> dict[str, Any]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError("Input must be a JSON object.")
    return data


def write_json(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def validate(data: dict[str, Any]) -> tuple[dict[str, Any], dict[str, Any]]:
    missing = [name for name in ("source",) if not data.get(name)]
    if missing:
        return data, {
            "state": "needs_input",
            "message": "Required information is missing.",
            "missing_fields": missing,
            "warnings": [],
        }
    normalized = {"source": str(data["source"]).strip(), "options": data.get("options", {})}
    return normalized, {"state": "valid", "message": "Input validation passed.", "missing_fields": [], "warnings": []}


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate and normalize skill input.")
    parser.add_argument("--input", required=True, type=Path, help="Path to input JSON.")
    parser.add_argument("--output", required=True, type=Path, help="Path to validation status JSON.")
    parser.add_argument("--normalized-output", type=Path, help="Path to normalized parameter JSON.")
    args = parser.parse_args()
    try:
        normalized, status = validate(read_object(args.input))
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        status = {"state": "invalid", "message": f"Invalid input: {exc}", "missing_fields": [], "warnings": []}
        write_json(args.output, status)
        return 2
    write_json(args.output, status)
    if status["state"] == "valid" and args.normalized_output:
        write_json(args.normalized_output, normalized)
    return 0 if status["state"] == "valid" else 1


if __name__ == "__main__":
    raise SystemExit(main())